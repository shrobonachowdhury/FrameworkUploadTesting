<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OpenCart Regression Suite" thread-count="5" parallel="tests" verbose="4">
  <test  name="Product Page Tests">
  <parameter name="browser" value="chrome"/>
    <classes>
      <class name="com.qa.opencart.tests.ProductInfoPageTest"/>
       </classes>
  </test> <!-- Test -->
  <test name="Account Page Tests">
  <parameter name="browser" value="firefox"/>
  <classes>
      <class name="com.qa.opencart.tests.AccountPageTest"/>
         </classes>
  </test> <!-- Test -->
  <test name="Login Page Tests">
  <parameter name="browser" value="edge"/>
  <classes>
      <class name="com.qa.opencart.tests.LoginPageTest"/>
             </classes>
  </test> <!-- Test -->
   <test name="Search Page Tests">
   <parameter name="browser" value="firefox"/>
  <classes>
      <class name="com.qa.opencart.tests.SearchTest"/>
     </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
